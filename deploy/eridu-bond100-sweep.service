[Unit]
Description=Eridu Bond 100 daily global /rank refresh
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=eridu
Group=eridu
WorkingDirectory=/opt/eridu-ops-api/services/bond100
Environment=PATH=/opt/eridu-ops-api/services/bond100/.venv/bin
Environment=PYTHONUNBUFFERED=1
# Same DB the API serves from (outside the code dir so git pull never touches it).
Environment=BOND100_DB_PATH=/opt/eridu-ops-api/var/bond100.sqlite
# ARONA_TOKEN ('<email>:<token>') lives in this file, VPS only, so the token
# binds to the VPS IP. Leading "-" tolerates the file being absent.
EnvironmentFile=-/opt/eridu-ops-api/.env
# Full global refresh: pages the entire bond-100 block and ATOMICALLY replaces the
# wall (~33-48 calls). Chosen over the --tail incremental because arona regenerates
# BOTH `key` and `rankUpdateTime` on every player refresh, so no per-record anchor
# dedups reliably across time, and an append-only tail can't see removals anyway.
# --global rebuilds from arona's ground truth each run: no drift, no ghosts, no dupes.
#
# --force: the daily rebuild MUST run, but the shared 20h budget window can be spent
# by manual --force runs or a submission spike beforehand -- that zeroed the gate and
# SKIPPED the Jul 09 run ("sweep budget left was 0"), leaving the wall a day stale.
# arona's ~60/day is soft (200+ observed) and --global is only ~48 calls, so forcing
# past OUR gate is safe. Calls are still logged, so the user-facing /refresh path
# still sees accurate usage; at 00:00 submission traffic is ~nil anyway.
ExecStart=/opt/eridu-ops-api/services/bond100/.venv/bin/python sweep_rank.py --global --force
